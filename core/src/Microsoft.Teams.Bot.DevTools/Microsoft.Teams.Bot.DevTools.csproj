<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <PackageId>Microsoft.Teams.Bot.DevTools</PackageId>
        <PackageDescription>Teams Bot DevTools — browser-based debugging UI for Teams bots</PackageDescription>
        <PackageProjectUrl>https://github.com/microsoft/teams.net</PackageProjectUrl>
        <PackageTags>microsoft;teams;msteams;bot;devtools;debugging</PackageTags>
    </PropertyGroup>

    <PropertyGroup>
        <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <GenerateEmbeddedFilesManifest>true</GenerateEmbeddedFilesManifest>
    </PropertyGroup>

    <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.FileProviders.Embedded" Version="9.0.0" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Microsoft.Teams.Bot.Core\Microsoft.Teams.Bot.Core.csproj" />
    </ItemGroup>

    <ItemGroup>
        <EmbeddedResource Include="web\**" />
    </ItemGroup>

</Project>
